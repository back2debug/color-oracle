{
    "components": {
        "schemas": {
            "Body_scan_image_v1_palette_scan_post": {
                "properties": {
                    "file": {
                        "description": "Photo of the item to analyze",
                        "format": "binary",
                        "title": "File",
                        "type": "string"
                    }
                },
                "required": [
                    "file"
                ],
                "title": "Body_scan_image_v1_palette_scan_post",
                "type": "object"
            },
            "ColorRequest": {
                "examples": [
                    {
                        "color": "#C4A882"
                    },
                    {
                        "color": "dusty rose"
                    },
                    {
                        "color": "rgb(196, 168, 130)"
                    }
                ],
                "properties": {
                    "color": {
                        "description": "The color to analyze. Accepts hex codes (#C4A882), RGB values (rgb(196, 168, 130)), or plain names (dusty rose, navy, terracotta).",
                        "examples": [
                            "#C4A882",
                            "rgb(196, 168, 130)",
                            "dusty rose"
                        ],
                        "title": "Color",
                        "type": "string"
                    }
                },
                "required": [
                    "color"
                ],
                "title": "ColorRequest",
                "type": "object"
            },
            "ColorSeason": {
                "enum": [
                    "Warm Spring",
                    "Light Spring",
                    "Bright Spring",
                    "Warm Autumn",
                    "Deep Autumn",
                    "Soft Autumn",
                    "Cool Winter",
                    "Deep Winter",
                    "Bright Winter",
                    "Cool Summer",
                    "Light Summer",
                    "Soft Summer"
                ],
                "title": "ColorSeason",
                "type": "string"
            },
            "ErrorResponse": {
                "properties": {
                    "error": {
                        "description": "Error code",
                        "title": "Error",
                        "type": "string"
                    },
                    "message": {
                        "description": "Explanation of what went wrong",
                        "title": "Message",
                        "type": "string"
                    }
                },
                "required": [
                    "error",
                    "message"
                ],
                "title": "ErrorResponse",
                "type": "object"
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "title": "Detail",
                        "type": "array"
                    }
                },
                "title": "HTTPValidationError",
                "type": "object"
            },
            "ImageScanResponse": {
                "properties": {
                    "dominant_color_name": {
                        "description": "Plain English name of the dominant color found",
                        "title": "Dominant Color Name",
                        "type": "string"
                    },
                    "hex_normalized": {
                        "description": "The dominant color as a hex code",
                        "pattern": "^#[0-9A-Fa-f]{6}$",
                        "title": "Hex Normalized",
                        "type": "string"
                    },
                    "item_description": {
                        "description": "A short description of what was detected in the image",
                        "title": "Item Description",
                        "type": "string"
                    },
                    "palette": {
                        "description": "A curated 5-color palette that works with the detected color",
                        "items": {
                            "$ref": "#/components/schemas/PaletteColor"
                        },
                        "title": "Palette",
                        "type": "array"
                    },
                    "season": {
                        "$ref": "#/components/schemas/ColorSeason",
                        "description": "The detected color season"
                    },
                    "season_match": {
                        "description": "How well this item's color fits the detected season",
                        "enum": [
                            "yes",
                            "maybe",
                            "no"
                        ],
                        "title": "Season Match",
                        "type": "string"
                    },
                    "undertone": {
                        "$ref": "#/components/schemas/Undertone"
                    },
                    "verdict": {
                        "description": "A direct, friendly verdict on whether this item works for the season",
                        "title": "Verdict",
                        "type": "string"
                    },
                    "vibe": {
                        "description": "A description of the season",
                        "title": "Vibe",
                        "type": "string"
                    }
                },
                "required": [
                    "item_description",
                    "dominant_color_name",
                    "hex_normalized",
                    "season",
                    "season_match",
                    "verdict",
                    "vibe",
                    "undertone",
                    "palette"
                ],
                "title": "ImageScanResponse",
                "type": "object"
            },
            "PaletteColor": {
                "properties": {
                    "hex": {
                        "description": "Hex color code",
                        "pattern": "^#[0-9A-Fa-f]{6}$",
                        "title": "Hex",
                        "type": "string"
                    },
                    "name": {
                        "description": "Human-readable color name",
                        "title": "Name",
                        "type": "string"
                    },
                    "role": {
                        "description": "Role this color plays in the palette",
                        "enum": [
                            "Base",
                            "Anchor",
                            "Light",
                            "Depth",
                            "Highlight"
                        ],
                        "title": "Role",
                        "type": "string"
                    }
                },
                "required": [
                    "hex",
                    "name",
                    "role"
                ],
                "title": "PaletteColor",
                "type": "object"
            },
            "PaletteResponse": {
                "properties": {
                    "color_input": {
                        "description": "The original color you sent",
                        "title": "Color Input",
                        "type": "string"
                    },
                    "hex_normalized": {
                        "description": "Your color converted to a hex code",
                        "pattern": "^#[0-9A-Fa-f]{6}$",
                        "title": "Hex Normalized",
                        "type": "string"
                    },
                    "palette": {
                        "description": "A curated 5-color palette that works with your color",
                        "items": {
                            "$ref": "#/components/schemas/PaletteColor"
                        },
                        "title": "Palette",
                        "type": "array"
                    },
                    "season": {
                        "$ref": "#/components/schemas/ColorSeason",
                        "description": "Your color season"
                    },
                    "undertone": {
                        "$ref": "#/components/schemas/Undertone"
                    },
                    "vibe": {
                        "description": "A human, personality-forward description of the season",
                        "title": "Vibe",
                        "type": "string"
                    }
                },
                "required": [
                    "color_input",
                    "hex_normalized",
                    "season",
                    "vibe",
                    "undertone",
                    "palette"
                ],
                "title": "PaletteResponse",
                "type": "object"
            },
            "SeasonDetail": {
                "properties": {
                    "description": {
                        "title": "Description",
                        "type": "string"
                    },
                    "id": {
                        "title": "Id",
                        "type": "string"
                    },
                    "name": {
                        "title": "Name",
                        "type": "string"
                    },
                    "signature_colors": {
                        "items": {
                            "type": "string"
                        },
                        "title": "Signature Colors",
                        "type": "array"
                    }
                },
                "required": [
                    "id",
                    "name",
                    "description",
                    "signature_colors"
                ],
                "title": "SeasonDetail",
                "type": "object"
            },
            "SeasonsResponse": {
                "properties": {
                    "seasons": {
                        "items": {
                            "$ref": "#/components/schemas/SeasonDetail"
                        },
                        "title": "Seasons",
                        "type": "array"
                    }
                },
                "required": [
                    "seasons"
                ],
                "title": "SeasonsResponse",
                "type": "object"
            },
            "Undertone": {
                "enum": [
                    "warm",
                    "cool",
                    "neutral"
                ],
                "title": "Undertone",
                "type": "string"
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "title": "Location",
                        "type": "array"
                    },
                    "msg": {
                        "title": "Message",
                        "type": "string"
                    },
                    "type": {
                        "title": "Error Type",
                        "type": "string"
                    }
                },
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError",
                "type": "object"
            }
        },
        "securitySchemes": {
            "APIKeyHeader": {
                "in": "header",
                "name": "X-API-Key",
                "type": "apiKey"
            }
        }
    },
    "info": {
        "description": "Send any color, get back your season, vibe, and a curated palette.",
        "title": "Color Whisperer API",
        "version": "1.0.0"
    },
    "openapi": "3.1.0",
    "paths": {
        "/": {
            "get": {
                "operationId": "root__get",
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        },
                        "description": "Successful Response"
                    }
                },
                "summary": "Root",
                "tags": [
                    "Health"
                ]
            }
        },
        "/health": {
            "get": {
                "operationId": "health_health_get",
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        },
                        "description": "Successful Response"
                    }
                },
                "summary": "Health",
                "tags": [
                    "Health"
                ]
            }
        },
        "/v1/palette": {
            "post": {
                "description": "Send any color \u2014 as a hex code, RGB value, or plain name like **dusty rose** \u2014 and get back:\n- Your **color season** (one of 12 seasonal archetypes)\n- A **description** written like a seasoned analyst, not a spec sheet\n- Your color's **undertone** (warm, cool, or neutral)\n- A curated **5-color palette** that flatters your color\n\nGreat for designers, stylists, or anyone who has ever stared at a paint swatch and felt nothing.",
                "operationId": "analyze_v1_palette_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ColorRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaletteResponse"
                                }
                            }
                        },
                        "description": "Successful Response"
                    },
                    "400": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        },
                        "description": "Could not parse the color input"
                    },
                    "401": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        },
                        "description": "Invalid API key"
                    },
                    "422": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        },
                        "description": "Validation Error"
                    },
                    "500": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        },
                        "description": "Something went wrong on our end"
                    }
                },
                "security": [
                    {
                        "APIKeyHeader": []
                    }
                ],
                "summary": "Analyze a color",
                "tags": [
                    "Color Whisperer"
                ]
            }
        },
        "/v1/palette/scan": {
            "post": {
                "description": "Upload a photo of any item \u2014 a sweater, a paint chip, a scarf, a couch cushion \u2014 and Color Whisperer will:\n\n1. **Identify the dominant color** of the item in the image\n2. **Determine the color season** it belongs to\n3. **Give you a verdict** on whether it works for that season\n4. **Return a full palette** of complementary colors\n\nPerfect for when you're out shopping and forgot your color swatches.\n\n**Supported formats:** JPEG, PNG, GIF  \n**Max file size:** 5MB",
                "operationId": "scan_image_v1_palette_scan_post",
                "requestBody": {
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/Body_scan_image_v1_palette_scan_post"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ImageScanResponse"
                                }
                            }
                        },
                        "description": "Successful Response"
                    },
                    "400": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        },
                        "description": "Invalid image or unsupported format"
                    },
                    "401": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        },
                        "description": "Invalid API key"
                    },
                    "413": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        },
                        "description": "Image too large"
                    },
                    "422": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        },
                        "description": "Validation Error"
                    },
                    "500": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        },
                        "description": "Something went wrong on our end"
                    }
                },
                "security": [
                    {
                        "APIKeyHeader": []
                    }
                ],
                "summary": "Scan an image for color analysis",
                "tags": [
                    "Color Whisperer"
                ]
            }
        },
        "/v1/palette/seasons": {
            "get": {
                "description": "Returns all 12 supported color seasons with descriptions and signature colors. Useful for building UI pickers or understanding the full seasonal color system.",
                "operationId": "list_seasons_v1_palette_seasons_get",
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SeasonsResponse"
                                }
                            }
                        },
                        "description": "Successful Response"
                    },
                    "401": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        },
                        "description": "Invalid API key"
                    }
                },
                "security": [
                    {
                        "APIKeyHeader": []
                    }
                ],
                "summary": "List all color seasons",
                "tags": [
                    "Color Whisperer"
                ]
            }
        }
    }
}
